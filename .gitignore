# =============================================================================
# driftforge-dots — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets and credentials
# -----------------------------------------------------------------------------
*.key
*.pem
*.env
.secrets/
secrets/

# -----------------------------------------------------------------------------
# SSH
# -----------------------------------------------------------------------------
.ssh/
id_rsa
id_ed25519
id_ecdsa
*.pub

# -----------------------------------------------------------------------------
# Hyprland runtime files
# -----------------------------------------------------------------------------
configs/hypr/.config/hypr/.hyprland_lock
configs/hypr/.config/hypr/hyprland.log
configs/hypr/.config/hypr/hyprpm/

# -----------------------------------------------------------------------------
# Kitty compiled config cache
# -----------------------------------------------------------------------------
configs/kitty/.config/kitty/cache/
configs/kitty/.config/kitty/*.pyc

# -----------------------------------------------------------------------------
# OS and editor clutter
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*~
*.swp
*.swo
.idea/
.vscode/

# -----------------------------------------------------------------------------
# Neovim swap and undo files
# -----------------------------------------------------------------------------
configs/nvim/.config/nvim/.swp
configs/nvim/.config/nvim/undo/
configs/nvim/.config/nvim/swap/
configs/nvim/.config/nvim/backup/

# -----------------------------------------------------------------------------
# GTK generated files
# -----------------------------------------------------------------------------
configs/gtk-3.0/.config/gtk-3.0/bookmarks

# -----------------------------------------------------------------------------
# Waybar compiled cache
# -----------------------------------------------------------------------------
configs/waybar/.config/waybar/cache/
